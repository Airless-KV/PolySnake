    "m_FunctionBody": "#if defined(SHADERGRAPH_PREVIEW)\r\n    ShadowAttenuation = 1.0;\r\n#else\r\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\r\n    Light light = GetMainLight(shadowCoord);\r\n    ShadowAttenuation = light.shadowAttenuation;\r\n#endif\r\n"
}

